{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "isolatedModules": true
  },
  "include": [
    "App.tsx",
    "src",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "ts-node": {
    "transpileOnly": true,
    "files": true
  },
  "extends": "expo/tsconfig.base"
}
