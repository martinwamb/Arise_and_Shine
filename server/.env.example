PORT=4000
JWT_SECRET=change-me
DB_FILE=./data.db
ALLOW_ORIGIN=*,http://localhost:5173
OPENAI_API_KEY=your-openai-key
OPENAI_ARTICLE_MODEL=gpt-4o-mini
OPENAI_INSIGHTS_MODEL=gpt-4o-mini
UNSPLASH_ACCESS_KEY=your-unsplash-key
PROTRACK_BASE_URL=https://api.protrack365.com
PROTRACK_ACCOUNT=
PROTRACK_PASSWORD=
PROTRACK_TRACK_PATH=/api/track
PROTRACK_TRACK_MODE=query
PROTRACK_TRACK_IMEIS=
PROTRACK_TRUCK_IMEI_MAP=
PROTRACK_ACCESS_TOKEN_PARAM=access_token
# Legacy/static token fallback (optional):
# PROTRACK_API_TOKEN=your-static-token
# PROTRACK_TRACK_URL=https://api.protrack365.com/api/track
# PROTRACK_API_URL=https://legacy-protrack-endpoint/api/v1
# PROTRACK_AUTH_URL=
# PROTRACK_AUTH_METHOD=POST
# PROTRACK_AUTH_FORMAT=json
# PROTRACK_AUTH_HEADERS={"X-Tenant":"your-tenant-id"}
PROTRACK_TENANT_ID=
LOW_STOCK_THRESHOLD=50
TELEMETRY_IDLE_THRESHOLD_MIN=120
ARTICLE_GENERATION_HOUR=5
ARTICLE_GENERATION_MINUTE=20
DISABLE_AUTO_ARTICLES=0
# TELEGRAM_BOT_TOKEN=1234567890:bot-token-from-botfather

# SMTP email delivery
# SMTP_URL=smtp://user:pass@mailtrap.io
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=0
SMTP_IGNORE_TLS=0
SMTP_FROM=no-reply@arise.local

# Notification dispatcher tuning
NOTIFICATION_DISPATCH_INTERVAL_MS=30000
NOTIFICATION_DISPATCH_BATCH=10
NOTIFICATION_MAX_ATTEMPTS=5

# Core role account overrides
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
ADMIN_PHONE=

OPS_EMAIL=
OPS_PASSWORD=
OPS_NAME=
OPS_PHONE=

